# Copy to .env.local and fill values. Never commit .env.local.

# Supabase — get from https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never expose to client

# PostHog — get from https://posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Dashboard — invent a strong password
DASHBOARD_PASSWORD=change-me
